
#ifndef __has_include
  #define __has_include(x) 0
#endif

#if __has_include(<SFML/Graphics.hpp>)
#include <SFML/Graphics.hpp>
#else

#include <cstddef>

namespace sf {
    struct Vector2f {
        float x, y;
        Vector2f(float X = 0.f, float Y = 0.f) : x(X), y(Y) {}
    };

    struct Color {
        unsigned char r, g, b, a;
        Color(unsigned char R = 0, unsigned char G = 0, unsigned char B = 0, unsigned char A = 255) : r(R), g(G), b(B), a(A) {}
        static const Color Cyan;
    };
    const Color Color::Cyan = Color(0, 255, 255);

    class ConvexShape {
    public:
        ConvexShape(int) {}
        void setPoint(std::size_t, Vector2f) {}
        void setFillColor(Color) {}
    };

    struct Event {
        enum EventType { Closed } ;
        EventType type;
    };

    class VideoMode {
    public:
        VideoMode(int, int) {}
    };

    class RenderWindow {
        bool openFlag = true;
        bool polledOnce = false;
    public:
        RenderWindow(VideoMode, const char*) {}
        bool isOpen() { return openFlag; }
        bool pollEvent(Event& e) {
            
            if (!polledOnce) {
                polledOnce = true;
                e.type = Event::Closed;
                return true;
            }
            return false;
        }
        void close() { openFlag = false; }
        void clear() {}
        void draw(const ConvexShape&) {}
        void display() {}
    };
}
#endif

#include <cmath>
#include <vector>


sf::Vector2f getMidpoint(sf::Vector2f p1, sf::Vector2f p2) {
    return sf::Vector2f((p1.x + p2.x) / 2.f, (p1.y + p2.y) / 2.f);
}


void drawSierpinski(sf::RenderWindow& window, sf::Vector2f a, sf::Vector2f b, sf::Vector2f c, int depth) {
    if (depth == 0) {
        
        sf::ConvexShape triangle(3);
        triangle.setPoint(0, a);
        triangle.setPoint(1, b);
        triangle.setPoint(2, c);
        triangle.setFillColor(sf::Color::Cyan);
        window.draw(triangle);
    }
    else {
      
        sf::Vector2f ab = getMidpoint(a, b);
        sf::Vector2f bc = getMidpoint(b, c);
        sf::Vector2f ca = getMidpoint(c, a);

      
        drawSierpinski(window, a, ab, ca, depth - 1);
        drawSierpinski(window, ab, b, bc, depth - 1);
        drawSierpinski(window, ca, bc, c, depth - 1);
    }
}

int main() {
    sf::RenderWindow window(sf::VideoMode(800, 800), "Sierpinski Triangle");

    sf::Vector2f p1(400, 50);
    sf::Vector2f p2(50, 750);
    sf::Vector2f p3(750, 750);

    int recursionDepth = 6; 

    while (window.isOpen()) {
        sf::Event event;
        while (window.pollEvent(event)) {
            if (event.type == sf::Event::Closed)
                window.close();
        }

        window.clear();
        drawSierpinski(window, p1, p2, p3, recursionDepth);
        window.display();
    }

    return 0;
}
